# Postgres (Supabase / Neon / any provider)
#
# On Render (and Vercel, GitHub Actions — any IPv4-only network): Supabase's
# direct connection host (db.<ref>.supabase.co) resolves IPv6-only on the free
# tier, causing `connect ENETUNREACH <ipv6 address>` at boot. Use the Supavisor
# SESSION POOLER connection string instead (IPv4, supports prepared statements
# — unlike transaction mode, which the pg driver adapter needs):
#   postgresql://postgres.<project-ref>:<password>@aws-<N>-<region>.pooler.supabase.com:5432/postgres
# Get the exact host/N from Supabase Dashboard -> Connect -> Session pooler.
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Google Gemini — used by AI module + question generation
GEMINI_API_KEY=

# Firebase Admin — paste service account JSON values (private key needs \n escaped)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# CORS allowlist
FRONTEND_URL=http://localhost:5173

# Optional: storage driver. Leave unset for local-disk under ./uploads
# STORAGE_DRIVER=s3
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# S3_BUCKET=ree-materials
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=https://cdn.example.com
