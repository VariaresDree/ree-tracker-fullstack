// ree-tracker-backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  // Removed deprecated "driverAdapters" preview feature
}

datasource db {
  provider = "postgresql"
  // Note: URL is configured in prisma.config.ts for Prisma v7+
}

enum Role {
  USER
  ADMIN
}

// 1 & 2. Merged 'users' and 'userData' collections
model User {
  id               String   @id
  email            String?  @unique
  displayName      String?
  photoURL         String?
  role             Role     @default(USER)
  globalStreak     Int      @default(0)
  thetaRating      Float    @default(0.0)
  standardError    Float    @default(0.5)
  lastActive       DateTime @default(now())
  createdAt        DateTime @default(now())
  
  // Legacy User Data Fields (Kept intact so the app doesn't crash)
  activityCalendar Json?
  thetaHistory     Json?
  matrix           Json?
  microTopics      Json?
  blindSpots       String[]
  
  // Settings
  examDate         String?
  dailyTarget      Int?     @default(50)

  // V1 Relations
  sessions         ExamSession[]
  attempts         QuestionAttempt[]
  bookmarks        Bookmark[]

  // --- V2 RELATIONAL ARRAYS (Fixes P1012) ---
  topicPerformances UserTopicPerformance[]
  thetaHistories    ThetaHistory[]
  activityLogs      ActivityLog[]

  // --- V3: Phase 2 Relations ---
  srsCards          SRSCard[]
  studySessions     StudySession[]
  plannerTasks      PlannerTask[]

  // --- V4: Phase 3 Relations ---
  readinessSnapshots ReadinessSnapshot[]

  // --- V5: Phase 4 Adaptive Engine Relations ---
  abilities          UserAbility[]
  forecastSnapshots  ForecastSnapshot[]

  // --- V6: Phase 6 Arena 2.0 — ELO + tiers ---
  eloRating          Int       @default(1200)
  tier               String    @default("BRONZE")
  gauntletLevel      Int       @default(1)
  battleOutcomes     BattleOutcome[]

  @@index([thetaRating])
  @@index([lastActive])
  @@index([eloRating])
}

// 3. 'questions' collection (Exact Firebase Names Restored)
model Question {
  id               String   @id @default(uuid())
  subject          String
  subtopic         String
  text             String
  options          String[]
  answer           String
  difficulty       Float    @default(0.0)
  fixedExplanation String?
  source           String?  @default("legacy")
  type             String?  @default("conceptual")
  isFlagged        Boolean  @default(false)
  createdAt        DateTime @default(now())

  // Phase 3: Bloom's taxonomy + difficulty tiers
  bloomLevel       String?  @default("REMEMBER")
  difficultyTier   Int?     @default(1)
  competencyArea   String?

  // Phase 3: Explanation review pipeline
  explanationStatus String? @default("PENDING")

  // Phase 4: IRT 3PL parameters. Nullable so legacy items can be drawn
  // at random until they accumulate enough attempts for calibration.
  irtA             Float?   // discrimination
  irtB             Float?   // difficulty (replaces overloaded `difficulty` over time)
  irtC             Float?   @default(0.20) // guess
  calibrationN     Int      @default(0)    // attempt count rolled into params
  lastCalibratedAt DateTime?

  attempts         QuestionAttempt[]
  bookmarks        Bookmark[]
  srsCards         SRSCard[]

  @@index([subject, irtB])
  // Readiness groupBy(['subtopic'], where:{isFlagged:false}) and pool sampling
  // (WHERE isFlagged=false ORDER BY random()) both filter on these — without an
  // index they full-scan the question bank on every readiness cache-miss and
  // every battle create.
  @@index([isFlagged, subtopic])
}

// 4. 'simulationHistory' collection
model ExamSession {
  id             String   @id @default(uuid())
  userId         String
  mode           String   
  targetSubject  String
  score          Int
  totalQuestions Int
  timeTakenSecs  Int
  verdict        String
  createdAt      DateTime @default(now())
  config         Json?    

  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempts       QuestionAttempt[]

  @@index([userId, createdAt])
}

model QuestionAttempt {
  id              String   @id @default(uuid())
  sessionId       String?
  userId          String
  questionId      String
  subject         String
  subtopic        String
  isCorrect       Boolean
  confidenceLevel String   @default("LOW")
  timeSpentMs     Int      @default(0)
  // Client-generated per-attempt id. Unique per user (NULLs distinct, so
  // legacy rows are unaffected) — the durable dedupe handle that stops
  // replayed telemetry batches from double-counting attempts.
  clientAttemptId String?
  // Which surface produced this attempt: ACTIVE_REVIEW | BOARD_SIM | GAUNTLET
  // | COMBAT | BATTLE | LEGACY. Indexed for dashboard mode-breakdown queries.
  mode            String   @default("LEGACY")
  createdAt       DateTime @default(now())

  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  question        Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  session         ExamSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, subject])
  @@index([userId, mode, createdAt])
  // Dashboard/readiness groupBys filter by userId and group by these — lets
  // Postgres index-scan the user's slice instead of a heap scan.
  @@index([userId, subtopic])
  @@index([userId, confidenceLevel, isCorrect])
  @@unique([userId, clientAttemptId])
}

// 5 & 6. 'folders' and 'materials' collections
model Folder {
  id        String     @id @default(uuid())
  name      String
  parentId  String?    
  createdAt DateTime   @default(now())
  materials Material[]
}

model Material {
  id          String   @id @default(uuid())
  name        String
  url         String
  type        String   
  storagePath String?
  folderId    String
  createdAt   DateTime @default(now())
  folder      Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)
}

model Bookmark {
  id         String   @id @default(uuid())
  userId     String
  questionId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  @@unique([userId, questionId]) 
}

// 7 & 8. 'systemConfig' and 'metadata' collections
model SystemConfig {
  id          String   @id @default("global_config")
  tos         Json?    
  metadata    Json?    
  updatedAt   DateTime @updatedAt
}

// 9. 'battles' collection
model Battle {
  id            String   @id
  hostId        String
  config        Json
  questions     Json
  timeLimitSecs Int
  status        String   @default("WAITING")
  createdAt     DateTime @default(now())
  outcomes      BattleOutcome[]
}

// Phase 6: per-participant battle outcomes. Persists ELO deltas so the
// replay/history view can render rank changes, and the leaderboard can
// query "matches played / last 7d win rate" cheaply.
model BattleOutcome {
  id              String   @id @default(uuid())
  battleId        String
  userId          String
  score           Int
  total           Int
  timeTakenSecs   Int
  placement       Int      // 1 = winner
  eloBefore       Int
  eloAfter        Int
  eloDelta        Int
  tierBefore      String
  tierAfter       String
  perQuestion     Json?    // [{ questionId, isCorrect, timeMs }] for replay
  createdAt       DateTime @default(now())

  battle          Battle   @relation(fields: [battleId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([battleId, userId])
  @@index([userId, createdAt])
}

model UserTopicPerformance {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject     String   // e.g., "Mathematics", "ESAS", "EE Professional"
  topic       String   // e.g., "AC Circuits", "Symmetrical Components"
  attempts    Int      @default(0)
  correct     Int      @default(0)
  totalTime   Int      @default(0) // Stored in seconds
  updatedAt   DateTime @updatedAt

  @@unique([userId, topic])
  @@index([userId, subject])
}

model ThetaHistory {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theta       Float    // Computed capability value
  recordedAt  DateTime @default(now())

  @@index([userId, recordedAt])
}

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        String   // Format: YYYY-MM-DD
  count       Int      @default(1)

  @@unique([userId, date])
  @@index([userId, date])
}

// Phase 2: Spaced Repetition System persistence
model SRSCard {
  id              String   @id @default(uuid())
  userId          String
  questionId      String
  easeFactor      Float    @default(2.5)
  interval        Int      @default(0)
  repetitions     Int      @default(0)
  nextReviewDate  DateTime
  lastReviewed    DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question        Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId, nextReviewDate])
}

// Phase 2: Active Review session tracking
model StudySession {
  id              String   @id @default(uuid())
  userId          String
  mode            String   // 'mcq', 'flashcard'
  subject         String
  subtopic        String?
  totalQuestions   Int
  correctAnswers  Int
  durationSecs    Int
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// Phase 2: Strategic Planner persistence
model PlannerTask {
  id          String    @id @default(uuid())
  userId      String
  text        String
  dueDate     String?
  completed   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, completed])
}

// Phase 4: Per-subject ability (IRT theta with standard error).
// The User.thetaRating remains as a back-compat global summary.
model UserAbility {
  id          String   @id @default(uuid())
  userId      String
  subject     String   // "Mathematics" | "ESAS" | "EE Professional" | "GLOBAL"
  theta       Float    @default(0.0)
  se          Float    @default(1.0)
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, subject])
  @@index([userId])
}

// Phase 4: Weekly forecast — pass / topnotcher probability with rationale.
model ForecastSnapshot {
  id                     String   @id @default(uuid())
  userId                 String
  passProbability        Float    // 0.0 .. 1.0
  topnotcherProbability  Float    // 0.0 .. 1.0
  expectedRank           Int?     // estimated percentile rank
  weakTopics             Json?    // [{ topic, theta, se, gapToTarget }]
  recommendedActions     Json?    // [{ type, payload, reason }]
  modelVersion           String   @default("v1")
  createdAt              DateTime @default(now())
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// Modular reference library — admin-managed engineering constants & formulas
// that SUPPLEMENT the bundled offline seed (config/knowledgeBase.js and
// ReferenceHub.jsx on the client). Global reference data, not per-user. The
// client merges these DB rows over the bundled seed (deduped by natural key)
// and caches them for offline use.
model EngineeringConstant {
  id        String   @id @default(uuid())
  category  String
  name      String
  value     String
  keyword   String?
  subject   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, name])
  @@index([category])
}

model EngineeringFormula {
  id        String   @id @default(uuid())
  subject   String
  title     String
  eq        String
  subtopics String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([subject, title])
  @@index([subject])
}

// Phase 3: Weekly readiness score snapshots
model ReadinessSnapshot {
  id              String   @id @default(uuid())
  userId          String
  score           Float
  topicCoverage   Float
  accuracyRate    Float
  theta           Float
  consistency     Float
  blindSpotRatio  Float
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
