// ree-tracker-backend/prisma/schema.prisma
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  // Note: URL is configured in prisma.config.ts for Prisma v7+
}

enum Role {
  USER
  ADMIN
}

// 1 & 2. Merged 'users' and 'userData' collections
model User {
  id               String   @id 
  role             Role     @default(USER) 
  globalStreak     Int      @default(0)
  thetaRating      Float    @default(0.0) 
  standardError    Float    @default(0.5)
  lastActive       DateTime @default(now())
  createdAt        DateTime @default(now())
  
  // Legacy User Data Fields
  activityCalendar Json?
  thetaHistory     Json?
  matrix           Json?
  microTopics      Json?
  blindSpots       String[]
  
  // Settings
  examDate         String?
  dailyTarget      Int?     @default(50)

  sessions         ExamSession[]
  attempts         QuestionAttempt[]
  bookmarks        Bookmark[]        
}

// 3. 'questions' collection (Exact Firebase Names Restored)
model Question {
  id               String   @id @default(uuid())
  subject          String   
  subtopic         String
  text             String   // Restored from Firebase
  options          String[] 
  answer           String   // Restored from Firebase
  difficulty       Float    @default(0.0) 
  fixedExplanation String?  // EXACT MATCH to Firebase 'Offline Solution'
  source           String?  @default("legacy")
  type             String?  @default("conceptual")
  isFlagged        Boolean  @default(false)
  createdAt        DateTime @default(now())

  attempts         QuestionAttempt[]
  bookmarks        Bookmark[]
}

// 4. 'simulationHistory' collection
model ExamSession {
  id             String   @id @default(uuid())
  userId         String
  mode           String   
  targetSubject  String
  score          Int
  totalQuestions Int
  timeTakenSecs  Int
  verdict        String
  createdAt      DateTime @default(now())
  config         Json?    

  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempts       QuestionAttempt[]
}

model QuestionAttempt {
  id              String   @id @default(uuid())
  sessionId       String?  
  userId          String
  questionId      String
  subject         String
  subtopic        String
  isCorrect       Boolean
  confidenceLevel String   @default("LOW")
  timeSpentMs     Int      @default(0)
  createdAt       DateTime @default(now())

  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  question        Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  session         ExamSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// 5 & 6. 'folders' and 'materials' collections
model Folder {
  id        String     @id @default(uuid())
  name      String
  parentId  String?    
  createdAt DateTime   @default(now())
  materials Material[]
}

model Material {
  id          String   @id @default(uuid())
  name        String
  url         String
  type        String   
  storagePath String?
  folderId    String
  createdAt   DateTime @default(now())
  folder      Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)
}

model Bookmark {
  id         String   @id @default(uuid())
  userId     String
  questionId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  @@unique([userId, questionId]) 
}

// 7 & 8. 'systemConfig' and 'metadata' collections
model SystemConfig {
  id          String   @id @default("global_config")
  tos         Json?    
  metadata    Json?    
  updatedAt   DateTime @updatedAt
}

// 9. 'battles' collection
model Battle {
  id            String   @id
  hostId        String
  config        Json
  questions     Json     
  timeLimitSecs Int
  status        String   @default("WAITING") 
  createdAt     DateTime @default(now())
}