// ree-tracker-backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  // Removed deprecated "driverAdapters" preview feature
}

datasource db {
  provider = "postgresql"
  // Note: URL is configured in prisma.config.ts for Prisma v7+
}

enum Role {
  USER
  ADMIN
}

// 1 & 2. Merged 'users' and 'userData' collections
model User {
  id               String   @id
  email            String?  @unique
  displayName      String?
  photoURL         String?
  role             Role     @default(USER)
  globalStreak     Int      @default(0)
  thetaRating      Float    @default(0.0)
  standardError    Float    @default(0.5)
  lastActive       DateTime @default(now())
  createdAt        DateTime @default(now())
  
  // Legacy User Data Fields (Kept intact so the app doesn't crash)
  activityCalendar Json?
  thetaHistory     Json?
  matrix           Json?
  microTopics      Json?
  blindSpots       String[]
  
  // Settings
  examDate         String?
  dailyTarget      Int?     @default(50)

  // V1 Relations
  sessions         ExamSession[]
  attempts         QuestionAttempt[]
  bookmarks        Bookmark[]

  // --- V2 RELATIONAL ARRAYS (Fixes P1012) ---
  topicPerformances UserTopicPerformance[]
  thetaHistories    ThetaHistory[]
  activityLogs      ActivityLog[]

  // --- V3: Phase 2 Relations ---
  srsCards          SRSCard[]
  studySessions     StudySession[]
  plannerTasks      PlannerTask[]

  // --- V4: Phase 3 Relations ---
  readinessSnapshots ReadinessSnapshot[]

  // --- V5: Phase 4 Adaptive Engine Relations ---
  abilities          UserAbility[]
  forecastSnapshots  ForecastSnapshot[]

  // --- V6: Phase 6 Arena 2.0 — ELO + tiers ---
  eloRating          Int       @default(1200)
  tier               String    @default("BRONZE")
  gauntletLevel      Int       @default(1)
  battleOutcomes     BattleOutcome[]

  // --- V7: Phase 4.2 — FCM push (Capacitor native app) ---
  deviceTokens       DeviceToken[]

  @@index([thetaRating])
  @@index([lastActive])
  @@index([eloRating])
}

// Phase 4.2: FCM registration tokens, one row per device. A token is globally
// unique; re-registration by a different user reassigns it (device changed
// hands). Dead tokens are pruned by pushService when FCM reports them
// unregistered.
model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String   @default("android") // android | ios | web
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Phase 3.3: canonical topic taxonomy (PRC REE board-exam TOS). One row per
// subtopic; Question.topicId points here. `aliases` carries legacy/curriculum
// labels ("Calculus 1") that resolve to the canonical topic ("Differential
// Calculus"), so historical strings keep attributing correctly. `curated:false`
// marks topics auto-created from unmatched legacy strings during migration —
// visible in the UI but pending an admin merge/rename.
model Topic {
  id        String   @id @default(uuid())
  subject   String            // canonical: 'Mathematics' | 'ESAS' | 'EE'
  name      String            // canonical display label (PRC TOS)
  normKey   String            // trim+lowercase name, the resolution key
  aliases   String[] @default([])  // legacy labels that resolve to this topic
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  curated   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questions         Question[]
  topicPerformances UserTopicPerformance[]
  referenceCards    ReferenceCard[]

  @@unique([subject, normKey])
  @@index([subject, active, sortOrder])
}

// 3. 'questions' collection (Exact Firebase Names Restored)
model Question {
  id               String   @id @default(uuid())
  subject          String
  subtopic         String
  // Phase 3.3: FK into the Topic taxonomy. Nullable so unmigrated/unresolved
  // questions stay fully functional through the legacy `subtopic` string
  // (which is rewritten to the canonical topic name once mapped).
  topicId          String?
  topic            Topic?   @relation(fields: [topicId], references: [id], onDelete: SetNull)
  text             String
  options          String[]
  answer           String
  difficulty       Float    @default(0.0)
  fixedExplanation String?
  source           String?  @default("legacy")
  type             String?  @default("conceptual")
  isFlagged        Boolean  @default(false)
  createdAt        DateTime @default(now())

  // Phase 3: Bloom's taxonomy + difficulty tiers
  bloomLevel       String?  @default("REMEMBER")
  difficultyTier   Int?     @default(1)
  competencyArea   String?

  // Phase 3: Explanation review pipeline
  explanationStatus String? @default("PENDING")

  // Phase 4: IRT 3PL parameters. Nullable so legacy items can be drawn
  // at random until they accumulate enough attempts for calibration.
  // Since Phase 3.4 these hold the SERVED values: the author-blended result
  // of the recalibration pipeline (w = n/(n+30) toward the empirical fit).
  irtA             Float?   // discrimination
  irtB             Float?   // difficulty (replaces overloaded `difficulty` over time)
  irtC             Float?   @default(0.20) // guess
  calibrationN     Int      @default(0)    // attempt count rolled into params
  lastCalibratedAt DateTime?

  // Phase 3.4: raw JMLE estimates from real response data. irtA/irtB above
  // hold the author-blended SERVED values; these keep the unblended empirical
  // estimate inspectable and let the blend be recomputed without re-running
  // JMLE. empiricalN = first-attempt responses behind the estimate.
  empiricalA       Float?
  empiricalB       Float?
  empiricalN       Int      @default(0)

  attempts         QuestionAttempt[]
  bookmarks        Bookmark[]
  srsCards         SRSCard[]

  @@index([subject, irtB])
  // Readiness groupBy(['subtopic'], where:{isFlagged:false}) and pool sampling
  // (WHERE isFlagged=false ORDER BY random()) both filter on these — without an
  // index they full-scan the question bank on every readiness cache-miss and
  // every battle create.
  @@index([isFlagged, subtopic])
  // Analytics/readiness aggregate attempts through Question→Topic joins.
  @@index([topicId])
}

// Phase 3.6: AI content review loop. AI/vision submissions land HERE, never in
// the live Question table — pool samplers can't leak an unreviewed item even if
// a query forgets a filter. Approve promotes into Question via the same create
// path as manual creation; reject is a SOFT state (auditable), never a delete.
model QuestionPendingReview {
  id                 String    @id @default(uuid())
  subject            String
  subtopic           String
  text               String
  options            String[]
  answer             String
  difficulty         Float     @default(2.0)
  fixedExplanation   String?
  source             String?   @default("ai")
  type               String?   @default("conceptual")
  bloomLevel         String?   @default("REMEMBER")
  difficultyTier     Int?      @default(1)
  status             String    @default("PENDING") // PENDING | APPROVED | REJECTED
  reviewNote         String?
  submittedBy        String?
  reviewedBy         String?
  reviewedAt         DateTime?
  promotedQuestionId String?   // live Question created on approve
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([status, createdAt])
}

// Phase 3.6: audit trail — review-stage lifecycle (SUBMITTED/EDITED/APPROVED/
// REJECTED, keyed by reviewId) and live-question edits (LIVE_EDIT, keyed by
// questionId, snapshot = the row BEFORE the edit). A wrong "correct answer"
// fix must always be traceable to who changed what, when.
model QuestionVersion {
  id         String   @id @default(uuid())
  questionId String?
  reviewId   String?
  action     String   // SUBMITTED | EDITED | APPROVED | REJECTED | LIVE_EDIT
  editor     String?  // uid; null for system/AI submission
  snapshot   Json
  createdAt  DateTime @default(now())

  @@index([questionId, createdAt])
  @@index([reviewId, createdAt])
}

// 4. 'simulationHistory' collection
model ExamSession {
  id             String   @id @default(uuid())
  userId         String
  mode           String   
  targetSubject  String
  score          Int
  totalQuestions Int
  timeTakenSecs  Int
  verdict        String
  createdAt      DateTime @default(now())
  config         Json?    

  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempts       QuestionAttempt[]

  @@index([userId, createdAt])
}

model QuestionAttempt {
  id              String   @id @default(uuid())
  sessionId       String?
  userId          String
  questionId      String
  subject         String
  subtopic        String
  isCorrect       Boolean
  confidenceLevel String   @default("LOW")
  timeSpentMs     Int      @default(0)
  // Client-generated per-attempt id. Unique per user (NULLs distinct, so
  // legacy rows are unaffected) — the durable dedupe handle that stops
  // replayed telemetry batches from double-counting attempts.
  clientAttemptId String?
  // Which surface produced this attempt: ACTIVE_REVIEW | BOARD_SIM | GAUNTLET
  // | COMBAT | BATTLE | LEGACY. Indexed for dashboard mode-breakdown queries.
  mode            String   @default("LEGACY")
  // True when this attempt was answered offline and synced later. The server
  // still re-grades it authoritatively on sync (it's never on the leaderboard
  // until then, since it only exists in the client outbox pre-sync); the flag is
  // for audit + surfacing client/server grading discrepancies.
  offline         Boolean  @default(false)
  createdAt       DateTime @default(now())

  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  question        Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  session         ExamSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, subject])
  @@index([userId, mode, createdAt])
  // Dashboard/readiness groupBys filter by userId and group by these — lets
  // Postgres index-scan the user's slice instead of a heap scan.
  @@index([userId, subtopic])
  @@index([userId, confidenceLevel, isCorrect])
  @@unique([userId, clientAttemptId])
}

// 5 & 6. 'folders' and 'materials' collections
model Folder {
  id        String     @id @default(uuid())
  name      String
  parentId  String?    
  createdAt DateTime   @default(now())
  materials Material[]
}

model Material {
  id          String   @id @default(uuid())
  name        String
  url         String
  type        String
  storagePath String?
  // Nullable = a root-level material (no parent folder). Uploading at the vault
  // root previously threw a Prisma P2003 FK violation against the virtual 'root'.
  folderId    String?
  createdAt   DateTime @default(now())
  folder      Folder?  @relation(fields: [folderId], references: [id], onDelete: Cascade)

  // FK filtered on every folder delete + cascade; Postgres doesn't auto-index FKs.
  @@index([folderId])
}

model Bookmark {
  id         String   @id @default(uuid())
  userId     String
  questionId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  @@unique([userId, questionId]) 
}

// 7 & 8. 'systemConfig' and 'metadata' collections
model SystemConfig {
  id          String   @id @default("global_config")
  tos         Json?
  metadata    Json?
  updatedAt   DateTime @updatedAt
}

// Phase 4.1: materialized leaderboard snapshot — rebuilt on an interval by
// services/leaderboardService (default every 45s; env LEADERBOARD_REFRESH_MS).
// Read endpoints serve THIS table instead of sorting/counting the live User
// table per request; a stale/empty snapshot falls back to the legacy live
// query once and triggers a refresh.
model LeaderboardEntry {
  rank         Int      @id
  userId       String   @unique
  displayName  String?
  role         String   @default("USER")
  thetaRating  Float
  eloRating    Int      @default(1200)
  tier         String   @default("BRONZE")
  globalStreak Int      @default(0)
  // Ranking stats surfaced in the Arena. activeDays = distinct Manila study
  // days; questionsAnswered = lifetime QuestionAttempt count; accuracy = 0..1.
  activeDays        Int   @default(0)
  questionsAnswered Int   @default(0)
  accuracy          Float @default(0)
  lastActive   DateTime
  snapshotAt   DateTime
}

// Phase 4.1: runtime feature flags — the rollout lever for later phases
// (e.g. Capacitor/FCM in 4.2). Read by all authed clients; admin-managed.
model FeatureFlag {
  key         String   @id
  enabled     Boolean  @default(false)
  payload     Json?
  description String?
  updatedAt   DateTime @updatedAt
}

// 9. 'battles' collection
model Battle {
  id            String   @id
  hostId        String
  config        Json
  questions     Json
  timeLimitSecs Int
  status        String   @default("WAITING")
  createdAt     DateTime @default(now())
  outcomes      BattleOutcome[]
}

// Phase 6: per-participant battle outcomes. Persists ELO deltas so the
// replay/history view can render rank changes, and the leaderboard can
// query "matches played / last 7d win rate" cheaply.
model BattleOutcome {
  id              String   @id @default(uuid())
  battleId        String
  userId          String
  score           Int
  total           Int
  timeTakenSecs   Int
  placement       Int      // 1 = winner
  eloBefore       Int
  eloAfter        Int
  eloDelta        Int
  tierBefore      String
  tierAfter       String
  perQuestion     Json?    // [{ questionId, isCorrect, timeMs }] for replay
  createdAt       DateTime @default(now())

  battle          Battle   @relation(fields: [battleId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([battleId, userId])
  @@index([userId, createdAt])
}

model UserTopicPerformance {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject     String   // e.g., "Mathematics", "ESAS", "EE Professional"
  topic       String   // canonical Topic.name once migrated; legacy string otherwise
  // Phase 3.3: FK into the taxonomy (nullable — legacy strings that never map
  // keep working through `topic`). The unique key stays [userId, topic].
  topicId     String?
  topicRef    Topic?   @relation(fields: [topicId], references: [id], onDelete: SetNull)
  attempts    Int      @default(0)
  correct     Int      @default(0)
  totalTime   Int      @default(0) // Stored in seconds
  // Phase 3.5: Bayesian Knowledge Tracing P(mastery) for this (user, topic).
  // Updated online per attempt in telemetryService; null until first observation.
  pMastery    Float?
  masteryN    Int      @default(0) // observations folded into pMastery (audit/debug)
  updatedAt   DateTime @updatedAt

  @@unique([userId, topic])
  @@index([userId, subject])
  @@index([topicId])
}

model ThetaHistory {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theta       Float    // Computed capability value
  recordedAt  DateTime @default(now())

  @@index([userId, recordedAt])
}

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        String   // Format: YYYY-MM-DD
  count       Int      @default(1)

  @@unique([userId, date])
  @@index([userId, date])
}

// Phase 2: Spaced Repetition System persistence
model SRSCard {
  id              String   @id @default(uuid())
  userId          String
  questionId      String
  easeFactor      Float    @default(2.5)
  interval        Int      @default(0)
  repetitions     Int      @default(0)
  nextReviewDate  DateTime
  lastReviewed    DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question        Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId, nextReviewDate])
}

// Phase 2: Active Review session tracking
model StudySession {
  id              String   @id @default(uuid())
  userId          String
  mode            String   // 'mcq', 'flashcard'
  subject         String
  subtopic        String?
  totalQuestions   Int
  correctAnswers  Int
  durationSecs    Int
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// Phase 2: Strategic Planner persistence
model PlannerTask {
  id          String    @id @default(uuid())
  userId      String
  text        String
  dueDate     String?
  completed   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, completed])
}

// Phase 4: Per-subject ability (IRT theta with standard error).
// The User.thetaRating remains as a back-compat global summary.
model UserAbility {
  id          String   @id @default(uuid())
  userId      String
  subject     String   // "Mathematics" | "ESAS" | "EE Professional" | "GLOBAL"
  theta       Float    @default(0.0)
  se          Float    @default(1.0)
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, subject])
  @@index([userId])
}

// Phase 4: Weekly forecast — pass / topnotcher probability with rationale.
model ForecastSnapshot {
  id                     String   @id @default(uuid())
  userId                 String
  passProbability        Float    // 0.0 .. 1.0
  topnotcherProbability  Float    // 0.0 .. 1.0
  expectedRank           Int?     // estimated percentile rank
  weakTopics             Json?    // [{ topic, theta, se, gapToTarget }]
  recommendedActions     Json?    // [{ type, payload, reason }]
  modelVersion           String   @default("v1")
  createdAt              DateTime @default(now())
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// Modular reference library — admin-managed engineering constants & formulas
// that SUPPLEMENT the bundled offline seed (config/knowledgeBase.js and
// ReferenceHub.jsx on the client). Global reference data, not per-user. The
// client merges these DB rows over the bundled seed (deduped by natural key)
// and caches them for offline use.
model EngineeringConstant {
  id        String   @id @default(uuid())
  category  String
  name      String
  value     String
  keyword   String?
  subject   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, name])
  @@index([category])
}

model EngineeringFormula {
  id        String   @id @default(uuid())
  subject   String
  title     String
  eq        String
  subtopics String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([subject, title])
  @@index([subject])
}

// ── Reference flashcard vault (replaces EngineeringConstant/EngineeringFormula) ──
// The two legacy tables above are DEPRECATED: nothing reads them anymore; their
// rows are wiped by scripts/wipeReferenceLegacy.js and the tables themselves get
// dropped in a later manual `db push --accept-data-loss` (the deploy build's
// plain `db push` intentionally fails on destructive changes).

// An authoritative source a card cites (textbook/edition, code/standard, PEC
// section) — keeps values traceable and bulk-updatable when a standard revises.
model ReferenceSource {
  id        String   @id @default(uuid())
  title     String            // e.g. "Philippine Electrical Code"
  kind      String?           // 'textbook' | 'code' | 'standard' | ...
  edition   String?           // e.g. "2017"
  section   String?           // e.g. "PEC 2.10.1.2"
  url       String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cards ReferenceCard[]

  @@unique([title, edition])
}

// One interactive flashcard: a constant, formula, or concept. Filed under the
// SHARED question-bank taxonomy (subject + Topic FK — never a parallel one);
// `subtopicTag` is a free-text finer label for grouping/search, NOT a taxonomy
// node. Content completeness is enforced by schemas/referenceCardSchemas at
// every entry point (AI intake, admin create/edit, bulk approve), with
// `dimensionless` as the controlled exception to the value requirement.
model ReferenceCard {
  id             String   @id @default(uuid())
  kind           String            // 'constant' | 'formula' | 'concept'
  symbol         String?           // e.g. "X_c"
  name           String            // e.g. "Capacitive Reactance"
  formulaLatex   String?           // required for kind='formula'
  valueUnit      String?           // required for kind='constant' unless dimensionless
  description    String            // plain-language meaning (required)
  variables      Json     @default("[]")  // [{ symbol, meaning, unit }] — must cover formulaLatex
  purposeExamTip String?           // board-exam application + common traps
  subject        String            // canonical: 'Mathematics' | 'ESAS' | 'EE'
  topicId        String?
  topic          Topic?   @relation(fields: [topicId], references: [id], onDelete: SetNull)
  subtopicTag    String?
  dimensionless  Boolean  @default(false)
  status         String   @default("PENDING") // PENDING | LIVE | REJECTED
  sourceId       String?
  source         ReferenceSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  submittedBy    String?
  reviewedBy     String?
  reviewedAt     DateTime?
  reviewNote     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([kind, subject, name])
  @@index([status, subject])
  @@index([topicId])
}

// Audit trail for card lifecycle (mirrors QuestionVersion): who did what, when,
// with a content snapshot. `cardId` is a plain string (no FK) so the audit
// history survives a card delete.
model ReferenceCardVersion {
  id        String   @id @default(uuid())
  cardId    String
  action    String            // SUBMITTED | CREATED | EDITED | APPROVED | REJECTED | DELETED
  editor    String?           // uid; null = system/AI
  snapshot  Json
  createdAt DateTime @default(now())

  @@index([cardId, createdAt])
}

// Phase 3: Weekly readiness score snapshots
model ReadinessSnapshot {
  id              String   @id @default(uuid())
  userId          String
  score           Float
  topicCoverage   Float
  accuracyRate    Float
  theta           Float
  consistency     Float
  blindSpotRatio  Float
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// PRC REE board-exam Table of Specifications — subject-level weights that
// constrain Board Simulator / blended-pool composition (Mathematics 25% / ESAS
// 30% / EE 45%). A runtime config table (seeded via scripts/seedSyllabusWeights.js)
// so the blend is editable without a deploy, and both the server sampler and the
// client exam builder read ONE source. Subtopics live in the Topic taxonomy
// (roadmap 3.3), not here — PRC publishes weights per subject, not per subtopic.
model SyllabusWeight {
  subject   String   @id // canonical: 'Mathematics' | 'ESAS' | 'EE'
  weight    Float        // fraction of the exam; rows should sum to ~1.0
  label     String?
  updatedAt DateTime @updatedAt
}
