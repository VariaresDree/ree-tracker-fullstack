{
  "compilerOptions": {
    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"],
      "@ui/*": ["components/ui/*"],
      "@motion/*": ["motion/*"],
      "@features/*": ["features/*"],
      "@services/*": ["services/*"],
      "@store/*": ["store/*"]
    },
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "checkJs": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
